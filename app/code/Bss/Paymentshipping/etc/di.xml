<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Quote\Model\Quote\Address">
        <plugin name="bss_shippingmethod_customer_group" type="Bss\Paymentshipping\Plugin\ShippingMethodManagement" sortOrder="10"/>
    </type>
    <type name="Magento\Payment\Model\MethodList">
        <plugin name="bss_paymentmethod_customer_group" type="Bss\Paymentshipping\Plugin\PaymentMethodList" sortOrder="10"/>
    </type>
    <type name="Magento\Payment\Block\Form\Container">
        <plugin name="bss_paymentmethod_form_customer_group" type="Bss\Paymentshipping\Plugin\FormPaymentMethodList" sortOrder="10"/>
    </type>
    <type name="Magento\Paypal\Model\AbstractConfig">
        <plugin name="bss_paymentmethod_add_shortcut" type="Bss\Paymentshipping\Plugin\AbstractConfig" sortOrder="10"/>
    </type>

    <preference for="Bss\Paymentshipping\Api\PaymentshippingManagementInterface" type="Bss\Paymentshipping\Model\PaymentshippingManagement" />
    <preference for="Bss\Paymentshipping\Api\PaymentshippingRepositoryInterface" type="Bss\Paymentshipping\Model\ResourceModel\PaymentshippingRepository" />
    <preference for="Bss\Paymentshipping\Api\Data\PaymentshippingInterface" type="Bss\Paymentshipping\Model\Paymentshipping" />
</config>
