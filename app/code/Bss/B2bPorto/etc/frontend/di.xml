<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Catalog\Controller\Category\View">
        <plugin name="bss_custom_ajax_layer_navigation"
                type="Bss\B2bPorto\Plugin\Controller\Category\View"
                sortOrder="1"/>
    </type>

    <type name="Magento\Catalog\Controller\Product\Compare\Add">
        <plugin name="bss_porto_layer_add_to_compare"
                type="Bss\B2bPorto\Plugin\Controller\Product\CompareWishlist"
                sortOrder="10"/>
    </type>
    <type name="Magento\Wishlist\Controller\Index\Add">
        <plugin name="bss_porto_layer_add_to_wishlist"
                type="Bss\B2bPorto\Plugin\Controller\Product\CompareWishlist"
                sortOrder="10"/>
    </type>
    <type name="Magento\Customer\CustomerData\SectionPoolInterface">
        <arguments>
            <argument name="sectionSourceMap" xsi:type="array">
                <item name="quote" xsi:type="string">Bss\QuoteExtension\CustomerData\QuoteExtension</item>
                <item name="directory-data" xsi:type="string">Bss\QuoteExtension\CustomerData\DirectoryData</item>
            </argument>
        </arguments>
    </type>

    <preference for="Bss\B2bRegistration\Plugin\Dob" type="Bss\B2bPorto\Plugin\Dob"/>
</config>
