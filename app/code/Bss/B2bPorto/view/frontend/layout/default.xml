<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>
        <move element="miniquoteextension" destination="porto_header" />
        <referenceContainer name="category.product.list.additional">
            <block name="add_multi_cart" template="Bss_B2bPorto::category/products.phtml"/>
        </referenceContainer>
        <referenceBlock name="porto_header">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Bss_B2bPorto::html/header.phtml</argument>
            </action>
        </referenceBlock>

        <referenceContainer name="after.body.start">
            <block class="Bss\MultiWishlist\Block\MultiWishlist"
                   name="bss.multiwishlist.popup" as="bss.multiwishlist.popup"
                   template="Bss_B2bPorto::multiwishlist/custom_multiwishlist.phtml" ifconfig="bss_multiwishlist/general/enable"/>
        </referenceContainer>
    </body>
</page>
